{
    "name": "swisseph/php-ffi",
    "description": "Complete PHP FFI Wrapper for Swiss Ephemeris C Library",
    "type": "library",
    "keywords": ["swiss-ephemeris", "astrology", "astronomy", "ffi", "ephemeris"],
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.3",
        "ext-ffi": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SwissEph\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SwissEph\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["SwissEph\\Service\\SwissEphServiceProvider"],
            "aliases": {"SwissEph": "SwissEph\\Service\\SwissEphFacade"}
        }
    },
    "scripts": {
        "build": "bash build/compile.sh",
        "test": "phpunit"
    }
}
